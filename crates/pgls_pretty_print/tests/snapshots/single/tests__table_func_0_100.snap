---
SELECT
  *
FROM
  JSON_TABLE(
    CAST('{"employees":[{"name":"Al","age":1}]}'
    AS JSONB),
    '$.employees[*]'
    COLUMNS (
      name text PATH '$.name',
      age INT PATH '$.age'
    )
  ) AS jt;
