CREATE TABLE test_jsonb_constraints (
  js TEXT,
  i INT,
  x JSONB
  DEFAULT JSON_QUERY(CAST('[1,2]'
  AS JSONB), '$[*]'
  WITH UNCONDITIONAL WRAPPER)
  CONSTRAINT "test_jsonb_constraint1" CHECK (js IS JSON)
  CONSTRAINT "test_jsonb_constraint2" CHECK (JSON_EXISTS(CAST(js
  AS JSONB), '$.a'
  PASSING i + 5 AS int,
  CAST(i
  AS TEXT) AS "TXT",
  ARRAY[1,
  2,
  3] AS arr))
  CONSTRAINT "test_jsonb_constraint3" CHECK (JSON_VALUE(CAST(js
  AS JSONB), '$.a'
  RETURNING INT
  DEFAULT '12' ON EMPTY
  ERROR ON ERROR) >
  i)
  CONSTRAINT "test_jsonb_constraint4" CHECK (JSON_QUERY(CAST(js
  AS JSONB), '$.a'
  WITH CONDITIONAL WRAPPER
  EMPTY OBJECT ON ERROR) =
  CAST('[10]'
  AS JSONB))
  CONSTRAINT "test_jsonb_constraint5" CHECK (JSON_QUERY(CAST(js
  AS JSONB), '$.a'
  RETURNING CHAR(5)
  OMIT QUOTES
  EMPTY ARRAY ON EMPTY) >
  'a' COLLATE "C")
);

SELECT
  check_clause
FROM
  information_schema.check_constraints
WHERE
  constraint_name LIKE 'test_jsonb_constraint%'
ORDER BY 1;

SELECT
  pg_get_expr(
  adbin,
  adrelid
  )
FROM
  pg_attrdef
WHERE
  adrelid =
  CAST('test_jsonb_constraints'
  AS REGCLASS)
ORDER BY 1;

