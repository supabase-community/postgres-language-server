SELECT
  ten,
  SUM(DISTINCT four)
FROM
  onek AS a
GROUP BY ten
HAVING
  EXISTS
  (SELECT
    1
  FROM
    onek AS b
  WHERE
    SUM(DISTINCT a.four) = b.four);

SELECT
  ten,
  SUM(DISTINCT four)
FROM
  onek AS a
GROUP BY ten
HAVING
  EXISTS
  (SELECT
    1
  FROM
    onek AS b
  WHERE
    SUM(DISTINCT a.four + b.four) =
    b.four);

