CREATE TABLE minmaxtest (f1 INT);

CREATE TABLE minmaxtest1
()
INHERITS (minmaxtest);

CREATE TABLE minmaxtest2
()
INHERITS (minmaxtest);

CREATE TABLE minmaxtest3
()
INHERITS (minmaxtest);

CREATE INDEX "minmaxtesti"
ON minmaxtest
USING btree
(
  f1
);

CREATE INDEX "minmaxtest1i"
ON minmaxtest1
USING btree
(
  f1
);

CREATE INDEX "minmaxtest2i"
ON minmaxtest2
USING btree
(
  f1 DESC
);

CREATE INDEX "minmaxtest3i"
ON minmaxtest3
USING btree
(
  f1
)
WHERE
  f1 IS NOT NULL;

