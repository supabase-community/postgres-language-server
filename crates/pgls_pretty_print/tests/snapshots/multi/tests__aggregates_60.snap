CREATE TEMPORARY TABLE t1
(
  a INT,
  b INT,
  c INT,
  d INT,
  PRIMARY KEY (a, b)
);

CREATE TEMPORARY TABLE t2
(
  x INT,
  y INT,
  z INT,
  PRIMARY KEY (x, y)
);

CREATE TEMPORARY TABLE t3
(
  a INT,
  b INT,
  c INT,
  PRIMARY KEY (a, b) DEFERRABLE
);

SELECT * FROM t1 GROUP BY a, b, c, d;

SELECT a, c FROM t1 GROUP BY a, c, d;

SELECT
  *
FROM
  t1
  INNER JOIN
    t2
  ON t1.a = t2.x AND t1.b = t2.y
GROUP BY t1.a,
  t1.b,
  t1.c,
  t1.d,
  t2.x,
  t2.y,
  t2.z;

SELECT
  t1.*,
  t2.x,
  t2.z
FROM
  t1
  INNER JOIN
    t2
  ON t1.a = t2.x AND t1.b = t2.y
GROUP BY t1.a,
  t1.b,
  t1.c,
  t1.d,
  t2.x,
  t2.z;

SELECT * FROM t3 GROUP BY a, b, c;

