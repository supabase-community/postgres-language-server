  AS DOUBLE PRECISION)
  )
FROM
  (SELECT * FROM tenk1
  UNION ALL
  SELECT * FROM tenk1
  UNION ALL
  SELECT * FROM tenk1
  UNION ALL
  SELECT * FROM tenk1)
