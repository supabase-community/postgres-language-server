FROM
  (SELECT * FROM tenk1
  UNION ALL
  SELECT * FROM tenk1
  UNION ALL
  SELECT * FROM tenk1
  UNION ALL
  SELECT * FROM tenk1)
  AS u;

ROLLBACK;

SELECT
  DENSE_RANK(
  x
  )
