    MIN(t1.f1)
  FROM
    int4_tbl AS t1
  WHERE
    t1.f1 = t0.f1)
FROM
  int4_tbl AS t0;

SELECT
  f1,
  (SELECT DISTINCT
    MIN(t1.f1)
  FROM
    int4_tbl AS t1
  WHERE
    t1.f1 = t0.f1)
FROM
  int4_tbl AS t0;

ROLLBACK;

