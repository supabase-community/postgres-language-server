  (VALUES
    (CAST(0 AS DOUBLE PRECISION)),
    (0.1),
    (0.25),
    (0.4),
    (0.5),
    (0.6),
    (0.75),
    (0.9),
    (1))
  AS v (p)
GROUP BY p
ORDER BY p;

