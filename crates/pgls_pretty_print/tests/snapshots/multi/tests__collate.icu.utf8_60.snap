SELECT
  getdatabaseencoding(

  ) <>
  'UTF8' OR
  (SELECT
    "COUNT"(
    *
    )
  FROM
    pg_collation
  WHERE
    collprovider =
    'i' AND
    collname <>
    'unicode') =
  0
  AS skip_test;

SET client_encoding TO utf8;

