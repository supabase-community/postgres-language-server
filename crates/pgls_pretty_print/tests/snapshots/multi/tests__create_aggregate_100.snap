SELECT
  aggfnoid,
  aggtransfn,
  aggcombinefn,
  CAST(aggtranstype AS REGTYPE),
  aggserialfn,
  aggdeserialfn,
  aggfinalmodify
FROM
  pg_aggregate
WHERE
  aggfnoid = CAST('myavg' AS REGPROC);

DROP AGGREGATE myavg(NUMERIC);

CREATE AGGREGATE myavg (NUMERIC)
(
  stype = internal,
  sfunc = numeric_avg_accum,
  finalfunc = numeric_avg
);

