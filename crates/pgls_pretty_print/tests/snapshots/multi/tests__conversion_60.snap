SELECT
  description,
  (test_conv(
  inbytes,
  'utf8',
  'utf8'
  )).*
FROM
  utf8_verification_inputs;

WITH
test_bytes
AS (
  SELECT
    inbytes,
    description,
    (test_conv(
    inbytes ||
    CAST(repeat('.', 3) AS BYTEA),
    'utf8',
    'utf8'
    )).error
  FROM
    utf8_verification_inputs
),
test_padded
AS (
  SELECT
    description,
    (test_conv(
    inbytes ||
    CAST(repeat('.', 64) AS BYTEA),
    'utf8',
    'utf8'
    )).error
  FROM
    test_bytes
)
SELECT
  description,
  b.error AS orig_error,
  p.error AS error_after_padding
FROM
  test_padded AS p
  INNER JOIN
    test_bytes AS b
  USING ("description")
WHERE
  p.error IS DISTINCT FROM b.error
ORDER BY description;

WITH
test_bytes
AS (
  SELECT
    inbytes,
    description,
    (test_conv(
    inbytes ||
    CAST(repeat('.', 3) AS BYTEA),
    'utf8',
    'utf8'
    )).error
  FROM
    utf8_verification_inputs
),
test_padded
AS (
  SELECT
    description,
    (test_conv(
    CAST(repeat(
    '.',
    64 - length(inbytes)
    )
    AS BYTEA) ||
    inbytes ||
    CAST(repeat('.', 64) AS BYTEA),
    'utf8',
    'utf8'
    )).error
  FROM
    test_bytes
)
SELECT
  description,
  b.error AS orig_error,
  p.error AS error_after_padding
FROM
  test_padded AS p
  INNER JOIN
    test_bytes AS b
  USING ("description")
WHERE
  p.error IS DISTINCT FROM b.error
ORDER BY description;

WITH
test_bytes
AS (
  SELECT
    inbytes,
    description,
    (test_conv(
    inbytes ||
    CAST(repeat('.', 3) AS BYTEA),
    'utf8',
