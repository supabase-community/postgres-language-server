SELECT * FROM pg_input_error_info('50000', 'int2vector');

SELECT * FROM int2_tbl AS f (a, b);

SELECT * FROM (SELECT * FROM int2_tbl) AS s (a, b);

SELECT
  i.*
FROM
  int2_tbl
  AS i
WHERE
  i.f1 <>
  CAST('0'
  AS SMALLINT);

SELECT
  i.*
FROM
  int2_tbl
  AS i
WHERE
  i.f1 <>
  CAST('0'
  AS INT);

SELECT
  i.*
FROM
  int2_tbl
  AS i
WHERE
  i.f1 =
  CAST('0'
  AS SMALLINT);

SELECT i.* FROM int2_tbl AS i WHERE i.f1 = CAST('0' AS INT);

SELECT
  i.*
FROM
  int2_tbl
  AS i
WHERE
  i.f1 <
  CAST('0'
  AS SMALLINT);

SELECT i.* FROM int2_tbl AS i WHERE i.f1 < CAST('0' AS INT);

