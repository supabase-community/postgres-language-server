  CAST('0'
  AS SMALLINT);

SELECT
  i.f1,
  i.f1 * CAST('2'
  AS SMALLINT)
  AS x
FROM
  int2_tbl
  AS i;

SELECT
  i.f1,
  i.f1 * CAST('2'
  AS SMALLINT)
  AS x
FROM
  int2_tbl
  AS i
WHERE
  abs(
  f1
  ) <
  16384;

SELECT
  i.f1,
  i.f1 * CAST('2'
  AS INT)
  AS x
FROM
  int2_tbl
  AS i;

SELECT
  i.f1,
  i.f1 + CAST('2'
  AS SMALLINT)
  AS x
FROM
  int2_tbl
  AS i;

SELECT
  i.f1,
  i.f1 + CAST('2'
  AS SMALLINT)
  AS x
FROM
  int2_tbl
  AS i
WHERE
  f1 <
  32766;

