  AS SMALLINT)
  AS TEXT);

SELECT CAST(-32768 AS SMALLINT) * CAST(-1 AS SMALLINT);

SELECT CAST(-32768 AS SMALLINT) / CAST(-1 AS SMALLINT);

SELECT CAST(-32768 AS SMALLINT) % CAST(-1 AS SMALLINT);

SELECT
  x,
  CAST(x
  AS SMALLINT)
  AS int2_value
FROM
  (VALUES (-CAST(2.5
  AS DOUBLE PRECISION)),
  (-CAST(1.5
  AS DOUBLE PRECISION)),
  (-CAST(0.5
  AS DOUBLE PRECISION)),
  (CAST(0.0
  AS DOUBLE PRECISION)),
  (CAST(0.5
  AS DOUBLE PRECISION)),
  (CAST(1.5
  AS DOUBLE PRECISION)),
  (CAST(2.5
  AS DOUBLE PRECISION))) AS t (x);

SELECT
  x,
  CAST(x
  AS SMALLINT)
  AS int2_value
FROM
  (VALUES (-CAST(2.5
  AS NUMERIC)),
  (-CAST(1.5
  AS NUMERIC)),
  (-CAST(0.5
  AS NUMERIC)),
  (CAST(0.0
  AS NUMERIC)),
  (CAST(0.5
  AS NUMERIC)),
  (CAST(1.5
  AS NUMERIC)),
  (CAST(2.5
  AS NUMERIC))) AS t (x);

