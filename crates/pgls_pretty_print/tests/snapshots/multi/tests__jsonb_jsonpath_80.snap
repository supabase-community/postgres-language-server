SELECT
  x,
  y,
  jsonb_path_query(
    '[true, false, null]',
    '$[*] ? (@ == true  &&  ($x == true && $y == true) ||
				 @ == false && !($x == true && $y == true) ||
				 @ == null  &&  ($x == true && $y == true) is unknown)',
    jsonb_build_object('x', x, 'y', y)
  )
  AS "x && y"
FROM
  (
    VALUES
      (CAST('true' AS JSONB)),
      ('false'),
      ('"null"')
  )
  AS x (x),
  (
    VALUES
      (CAST('true' AS JSONB)),
      ('false'),
      ('"null"')
  )
  AS y (y);

SELECT
  x,
  y,
  jsonb_path_query(
    '[true, false, null]',
    '$[*] ? (@ == true  &&  ($x == true || $y == true) ||
				 @ == false && !($x == true || $y == true) ||
				 @ == null  &&  ($x == true || $y == true) is unknown)',
    jsonb_build_object('x', x, 'y', y)
  )
  AS "x || y"
FROM
  (
    VALUES
      (CAST('true' AS JSONB)),
      ('false'),
      ('"null"')
  )
  AS x (x),
  (
    VALUES
      (CAST('true' AS JSONB)),
      ('false'),
      ('"null"')
  )
  AS y (y);

