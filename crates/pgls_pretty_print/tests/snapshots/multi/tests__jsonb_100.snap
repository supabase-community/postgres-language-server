SELECT
  jsonb_build_object(
    'a',
    jsonb_build_object('b', FALSE, 'c', 99),
    'd',
    jsonb_build_object(
      'e',
      CAST(ARRAY[9, 8, 7] AS INT[]),
      'f',
      (
        SELECT
          row_to_json(r)
        FROM
          (
            SELECT
              relkind,
              CAST(oid AS REGCLASS) AS name
            FROM
              pg_class
            WHERE
              relname = 'pg_class'
          )
          AS r
      )
    )
  );

