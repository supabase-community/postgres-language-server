SELECT CAST('[{"b": "c"}, {"b": "cc"}]' AS JSONB) #>> ARRAY['1', 'b'];

SELECT CAST('[{"b": "c"}, {"b": "cc"}]' AS JSONB) #>> ARRAY['z', 'b'];

SELECT CAST('[{"b": "c"}, {"b": null}]' AS JSONB) #>> ARRAY['1', 'b'];

SELECT CAST('"foo"' AS JSONB) #>> ARRAY['z'];

SELECT CAST('42' AS JSONB) #>> ARRAY['f2'];

