RETURNS NUMERIC
AS '
begin
  raise notice ''non-variadic function called'';
  return $1;
end;
'
LANGUAGE "plpgsql"
IMMUTABLE
STRICT;

SELECT pleast(10);

DROP FUNCTION pleast(NUMERIC[]);

