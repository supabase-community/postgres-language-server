CREATE FUNCTION namedparmcursor_test5()
RETURNS VOID
AS '
declare
  c1 cursor (p1 int, p2 int) for
    select * from tenk1 where thousand = p1 and tenthous = p2;
begin
  open c1 (p2 := 77, p2 := 42);
end
'
LANGUAGE "plpgsql";

