RETURNS VOID
AS '
declare
    a integer[] = ''{10,20,30}'';
    c varchar = ''xyz'';
    i integer;
begin
    i := 2;
    raise notice ''%; %; %; %; %; %'', a, a[i], c, (select c || ''abc''), row(10,''aaa'',NULL,30), NULL;
end;'
LANGUAGE "plpgsql";

SELECT raise_exprs();

