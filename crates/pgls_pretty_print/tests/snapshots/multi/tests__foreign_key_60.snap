SELECT
  pg_describe_object(
  CAST('pg_constraint'
  AS REGCLASS),
  oid,
  0
  ),
  CAST(confrelid
  AS REGCLASS),
  CASE
  WHEN conparentid <>
  0 THEN pg_describe_object(
  CAST('pg_constraint'
  AS REGCLASS),
  conparentid,
  0
  )
  ELSE 'TOP'
  END
FROM
  pg_catalog.pg_constraint
WHERE
  conrelid IN (SELECT
    relid
  FROM
    pg_partition_tree(
    'fk'
    ))
ORDER BY CAST(CAST(conrelid
  AS REGCLASS)
  AS TEXT),
  conname;

