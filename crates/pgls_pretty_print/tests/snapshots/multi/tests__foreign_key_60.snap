SELECT
  conname,
  CAST(tgrelid
  AS REGCLASS)
  AS tgrel,
  regexp_replace(
  tgname,
  '[0-9]+',
  'N'
  )
  AS tgname,
  tgtype
FROM
  pg_trigger
  AS t
  INNER JOIN pg_constraint
  AS c
  ON t.tgconstraint =
    c.oid
WHERE
  tgrelid IN (SELECT
    relid
  FROM
    pg_partition_tree(
    CAST('fk_partitioned_fk'
    AS REGCLASS)
    )
  UNION ALL
  SELECT
    CAST('fk_notpartitioned_pk'
    AS REGCLASS))
ORDER BY tgrelid,
  tgtype;

