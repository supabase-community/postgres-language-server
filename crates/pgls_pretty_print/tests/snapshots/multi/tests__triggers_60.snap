ON parted_trig
FOR EACH ROW
EXECUTE FUNCTION trigger_notice();

CREATE TRIGGER parted_trig_after_row
AFTER INSERT OR DELETE OR UPDATE
ON parted_trig
FOR EACH ROW
EXECUTE FUNCTION trigger_notice();

CREATE TRIGGER parted_trig_after_stmt
AFTER INSERT OR DELETE OR UPDATE
ON parted_trig
FOR EACH STATEMENT
EXECUTE FUNCTION trigger_notice();

