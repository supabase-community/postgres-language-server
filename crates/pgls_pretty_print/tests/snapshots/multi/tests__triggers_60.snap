AFTER INSERT
ON grandparent
FOR EACH ROW
EXECUTE FUNCTION f();

ALTER TRIGGER a ON grandparent RENAME TO b;

SELECT
  CAST(tgrelid AS REGCLASS),
  tgname,
  (SELECT
    tgname
  FROM
    pg_trigger AS tr
  WHERE
    tr.oid = pg_trigger.tgparentid)
  AS parent_tgname
FROM
  pg_trigger
WHERE
  tgrelid IN
  (SELECT
    relid
  FROM
    pg_partition_tree(
    'grandparent'
    ))
ORDER BY tgname,
  CAST(CAST(tgrelid AS REGCLASS)
  AS TEXT) COLLATE "C";

