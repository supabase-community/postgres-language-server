CREATE FUNCTION trigger_func()
RETURNS trigger
LANGUAGE "plpgsql"
AS '
BEGIN
	RAISE NOTICE ''trigger_func(%) called: action = %, when = %, level = %'', TG_ARGV[0], TG_OP, TG_WHEN, TG_LEVEL;
	RETURN NULL;
END;';

