SELECT
  trigger_name,
  event_manipulation,
  event_object_schema,
  event_object_table,
  action_order,
  action_condition,
  action_orientation,
  action_timing,
  action_reference_old_table,
  action_reference_new_table
FROM
  information_schema.triggers
WHERE
  event_object_table
  IN (
    'parent',
    'child1',
    'child2',
    'child3'
  )
ORDER BY trigger_name COLLATE "C",
  2;

