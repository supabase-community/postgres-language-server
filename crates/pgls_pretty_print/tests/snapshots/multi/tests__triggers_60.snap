AS '
  begin
    raise notice ''trigger % on % % % for %'', TG_NAME, TG_TABLE_NAME, TG_WHEN, TG_OP, TG_LEVEL;
    if TG_LEVEL = ''ROW'' then
       return NEW;
    end if;
    return null;
  end;
  '
