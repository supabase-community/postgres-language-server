CREATE TABLE trigger_test (f1 INT, f2 TEXT, f3 TEXT);

CREATE FUNCTION mytrigger()
RETURNS trigger
LANGUAGE "plpgsql"
AS '
begin
	if row(old.*) = row(new.*) then
		raise notice ''row % not changed'', new.f1;
	else
		raise notice ''row % changed'', new.f1;
	end if;
	return new;
end';

CREATE TRIGGER t
BEFORE UPDATE
ON trigger_test
FOR EACH ROW
EXECUTE FUNCTION mytrigger();

