AFTER UPDATE
ON parent
REFERENCING OLD TABLE AS old_table
NEW TABLE AS new_table
FOR EACH STATEMENT
EXECUTE FUNCTION dump_update();

CREATE TRIGGER parent_delete_trig
AFTER DELETE
ON parent
REFERENCING OLD TABLE AS old_table
FOR EACH STATEMENT
EXECUTE FUNCTION dump_delete();

