CREATE INDEX "onek2_u1_prtl"
ON onek2
USING btree
(
  unique1 int4_ops
)
WHERE
  unique1 < 20 OR unique1 > 980;

CREATE INDEX "onek2_u2_prtl"
ON onek2
USING btree
(
  unique2 int4_ops
)
WHERE
  stringu1 < 'B';

CREATE INDEX "onek2_stu1_prtl"
ON onek2
USING btree
(
  stringu1 name_ops
)
WHERE
  onek2.stringu1 >= 'J' AND onek2.stringu1 < 'K';

