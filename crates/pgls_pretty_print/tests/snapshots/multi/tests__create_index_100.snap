SELECT
  b.relname,
  b.relkind,
  CASE
  WHEN a.relfilenode = b.relfilenode
  THEN 'relfilenode is unchanged'
  ELSE 'relfilenode has changed'
  END
FROM
  reindex_before AS b
  INNER JOIN
    pg_class AS a
  ON b.oid = a.oid
ORDER BY 1;

