INSERT INTO unique_tbl (t) VALUES ('seven');

DROP INDEX "unique_idx1", "unique_idx2";

INSERT INTO unique_tbl (t) VALUES ('seven');

CREATE UNIQUE INDEX "unique_idx3"
ON unique_tbl
USING btree
(
  i
);

