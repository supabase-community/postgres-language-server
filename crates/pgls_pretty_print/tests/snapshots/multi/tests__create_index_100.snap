INSERT INTO unique_tbl VALUES (2, 'two');

INSERT INTO unique_tbl VALUES (3, 'three');

INSERT INTO unique_tbl VALUES (4, 'four');

INSERT INTO unique_tbl VALUES (5, 'one');

