SET ROLE TO regress_reindexuser;

REINDEX TABLE pg_toast.pg_toast_1262;

REINDEX INDEX pg_toast.pg_toast_1262_index;

RESET role;

REVOKE USAGE ON SCHEMA pg_toast FROM regress_reindexuser;

DROP ROLE regress_reindexuser;

