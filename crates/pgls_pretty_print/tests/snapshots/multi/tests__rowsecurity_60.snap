UPDATE t2
SET b = t2.b
FROM t3
WHERE
  t2.a =
  3 AND
  t3.a =
  2 AND
  f_leak(
  t2.b
  ) AND
  f_leak(
  t3.b
  );

UPDATE t2
SET b = t2.b
FROM t3
WHERE
