CREATE OR REPLACE FUNCTION
f_leak(
  TEXT
)
RETURNS BOOLEAN
COST 0.0000001
LANGUAGE "plpgsql"
AS 'BEGIN RAISE NOTICE ''f_leak => %'', $1; RETURN true; END';

GRANT EXECUTE ON FUNCTION f_leak(TEXT) TO PUBLIC;

