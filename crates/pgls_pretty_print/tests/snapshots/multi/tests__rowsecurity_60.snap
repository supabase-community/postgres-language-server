CREATE POLICY p2
ON category
AS PERMISSIVE
FOR ALL
TO PUBLIC
USING (CASE
WHEN CURRENT_USER =
'regress_rls_bob' THEN cid IN (11,
33)
WHEN CURRENT_USER =
'regress_rls_carol' THEN cid IN (22,
44)
ELSE FALSE
END);

