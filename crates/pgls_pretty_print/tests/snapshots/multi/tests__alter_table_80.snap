SELECT
  conname,
  CAST(tgfoid AS REGPROC),
  tgtype,
  tgdeferrable,
  tginitdeferred
FROM
  pg_trigger
  INNER JOIN
    pg_constraint AS con
  ON con.oid = tgconstraint
WHERE
  tgrelid = CAST('pktable' AS REGCLASS)
ORDER BY 1,
  2,
  3;

SELECT
  conname,
  CAST(tgfoid AS REGPROC),
  tgtype,
  tgdeferrable,
  tginitdeferred
FROM
  pg_trigger
  INNER JOIN
    pg_constraint AS con
  ON con.oid = tgconstraint
WHERE
  tgrelid = CAST('fktable' AS REGCLASS)
ORDER BY 1,
  2,
  3;

