SELECT
  CAST(relation AS REGCLASS),
  mode
FROM
  pg_locks
WHERE
  pid = pg_backend_pid() AND
  locktype = 'relation' AND
  CAST(CAST(relation AS REGCLASS) AS TEXT) LIKE 'alter\_idx%'
ORDER BY CAST(CAST(relation AS REGCLASS) AS TEXT) COLLATE "C";

COMMIT;

