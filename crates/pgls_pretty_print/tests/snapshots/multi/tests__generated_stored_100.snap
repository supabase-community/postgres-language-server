CREATE FUNCTION gtest_trigger_func3()
RETURNS trigger
LANGUAGE "plpgsql"
AS '
BEGIN
  RAISE NOTICE ''OK'';
  RETURN NEW;
END
';

CREATE TRIGGER gtest11
  BEFORE UPDATE OF b
  ON gtest26
  FOR EACH ROW
  EXECUTE FUNCTION gtest_trigger_func3();

UPDATE gtest26 SET a = 1 WHERE a = 0;

