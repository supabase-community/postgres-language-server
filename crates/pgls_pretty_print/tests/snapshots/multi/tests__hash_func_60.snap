    ('00:11:52.62+01'),
    ('11:59:59+04'))
  AS x (v)
WHERE
  CAST(timetz_hash(v)
  AS BIT(32)) <>
  CAST(timetz_hash_extended(v, 0)
  AS BIT(32)) OR
