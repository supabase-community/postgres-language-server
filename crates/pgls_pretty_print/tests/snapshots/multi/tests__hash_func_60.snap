  AS BIT(32))
  AS extended0,
  CAST(timetz_hash_extended(v, 1)
  AS BIT(32))
  AS extended1
FROM
  (VALUES
    (
      CAST(NULL
      AS TIME WITH TIME ZONE)
    ),
    ('00:11:52.518762-07'),
    ('00:11:52.51762-08'),
