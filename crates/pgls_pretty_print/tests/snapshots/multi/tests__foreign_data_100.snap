SELECT
  relname,
  conname,
  contype,
  conislocal,
  coninhcount,
  connoinherit
FROM
  pg_class AS pc
  INNER JOIN
    pg_constraint AS pgc
  ON conrelid = pc.oid
WHERE
  pc.relname = 'fd_pt1'
ORDER BY 1,
  2;

