CONCURRENTLY "parted_isvalid_idx_11" ON parted_isvalid_tab_11 USING btree
(
  (a / b)
);

CREATE INDEX "parted_isvalid_idx" ON parted_isvalid_tab USING btree
(
  (a / b)
);

