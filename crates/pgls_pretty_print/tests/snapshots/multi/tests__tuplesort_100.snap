SELECT
  left(a, 10),
  b
FROM
  (
    VALUES
      (repeat('a', 512 * 1024), 1),
      (repeat('b', 512 * 1024), 2)
  )
  AS v (a, b)
ORDER BY v.a DESC;

BEGIN;

SET LOCAL enable_indexscan = 'false';

EXPLAIN (COSTS 'off')
DECLARE "c" SCROLL
CURSOR
FOR SELECT
  noabort_decreasing
FROM
  abbrev_abort_uuids
ORDER BY noabort_decreasing;;

DECLARE "c" SCROLL
CURSOR
FOR SELECT
  noabort_decreasing
FROM
  abbrev_abort_uuids
ORDER BY noabort_decreasing;;

FETCH NEXT FROM c;

FETCH NEXT FROM c;

FETCH PRIOR FROM c;

FETCH PRIOR FROM c;

FETCH PRIOR FROM c;

FETCH PRIOR FROM c;

FETCH NEXT FROM c;

FETCH ABSOLUTE -1 FROM c;

FETCH PRIOR FROM c;

FETCH NEXT FROM c;

FETCH NEXT FROM c;

FETCH NEXT FROM c;

FETCH PRIOR FROM c;

FETCH NEXT FROM c;

COMMIT;

BEGIN;

