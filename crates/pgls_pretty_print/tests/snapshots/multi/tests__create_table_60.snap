ALTER TABLE defcheck ATTACH PARTITION defcheck_def DEFAULT;

ALTER TABLE defcheck_def
  ADD CHECK (b <=
  0 AND
  b IS NOT NULL);

CREATE TABLE defcheck_1
PARTITION OF defcheck
FOR VALUES IN (1,
NULL);

INSERT INTO defcheck_def VALUES (0, 0);

