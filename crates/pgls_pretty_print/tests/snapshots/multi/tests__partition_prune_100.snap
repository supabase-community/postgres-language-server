CREATE FUNCTION explain_analyze(query TEXT)
RETURNS SETOF TEXT
LANGUAGE "plpgsql"
AS '
declare
    ln text;
begin
    for ln in
        execute format(''explain (analyze, costs off, summary off, timing off, buffers off) %s'',
            query)
    loop
        ln := regexp_replace(ln, ''Maximum Storage: \d+'', ''Maximum Storage: N'');
        return next ln;
    end loop;
end;
';

SET plan_cache_mode = force_generic_plan;

CREATE TABLE lp (a CHAR(1))
PARTITION BY LIST(a);

