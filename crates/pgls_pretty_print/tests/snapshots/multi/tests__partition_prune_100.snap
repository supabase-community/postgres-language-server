SELECT
  *
FROM
  (SELECT
    EXISTS (SELECT
      1
    FROM
      int4_tbl AS tinner
    WHERE
      f1 = touter.f1)
    AS b
  FROM
    int4_tbl AS touter) AS ss,
  asptab
WHERE
  asptab.id > CAST(ss.b AS INT);

DROP TABLE "asptab";

