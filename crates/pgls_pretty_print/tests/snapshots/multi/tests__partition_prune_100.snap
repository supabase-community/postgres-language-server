SELECT * FROM part AS p (x) ORDER BY x;

SELECT
  *
FROM
  mc2p AS t1,
  LATERAL (SELECT
    COUNT(*)
  FROM
    mc3p AS t2
  WHERE
    t2.a = t1.b AND abs(t2.b) = 1 AND t2.c = 1) AS s
WHERE
  t1.a = 1;

SELECT
  *
FROM
  mc2p AS t1,
  LATERAL (SELECT
    COUNT(*)
  FROM
    mc3p AS t2
  WHERE
    t2.c = t1.b AND abs(t2.b) = 1 AND t2.a = 1) AS s
WHERE
  t1.a = 1;

SELECT
  *
FROM
  mc2p AS t1,
  LATERAL (SELECT
    COUNT(*)
  FROM
    mc3p AS t2
  WHERE
    t2.a = 1 AND abs(t2.b) = 1 AND t2.c = 1) AS s
WHERE
  t1.a = 1;

