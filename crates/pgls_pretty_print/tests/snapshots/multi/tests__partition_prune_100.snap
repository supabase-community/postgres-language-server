PREPARE q (INT,
INT) AS SELECT
  *
FROM
  (SELECT * FROM p UNION ALL SELECT * FROM q1
  UNION ALL
  SELECT 1, 1, 1) AS s (a, b, c)
WHERE
  s.a = $1 AND s.b = $2 AND s.c = (SELECT 1);;

