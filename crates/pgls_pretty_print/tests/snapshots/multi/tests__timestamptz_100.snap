SELECT to_char(NOW(), 'OF') AS "OF", to_char(NOW(), 'TZH:TZM') AS "TZH:TZM";

RESET timezone;

SET TIME ZONE '00:00';

SELECT to_char(NOW(), 'of') AS "Of", to_char(NOW(), 'tzh:tzm') AS "tzh:tzm";

SET TIME ZONE '+02:00';

SELECT to_char(NOW(), 'of') AS of, to_char(NOW(), 'tzh:tzm') AS "tzh:tzm";

SET TIME ZONE '-13:00';

SELECT to_char(NOW(), 'of') AS of, to_char(NOW(), 'tzh:tzm') AS "tzh:tzm";

SET TIME ZONE '-00:30';

SELECT to_char(NOW(), 'of') AS of, to_char(NOW(), 'tzh:tzm') AS "tzh:tzm";

SET TIME ZONE '00:30';

SELECT to_char(NOW(), 'of') AS of, to_char(NOW(), 'tzh:tzm') AS "tzh:tzm";

SET TIME ZONE '-04:30';

SELECT to_char(NOW(), 'of') AS of, to_char(NOW(), 'tzh:tzm') AS "tzh:tzm";

SET TIME ZONE '04:30';

SELECT to_char(NOW(), 'of') AS of, to_char(NOW(), 'tzh:tzm') AS "tzh:tzm";

SET TIME ZONE '-04:15';

SELECT to_char(NOW(), 'of') AS of, to_char(NOW(), 'tzh:tzm') AS "tzh:tzm";

SET TIME ZONE '04:15';

SELECT to_char(NOW(), 'of') AS of, to_char(NOW(), 'tzh:tzm') AS "tzh:tzm";

RESET timezone;

CREATE TABLE timestamptz_tst (
  a INT,
  b TIMESTAMP WITH TIME ZONE
);

