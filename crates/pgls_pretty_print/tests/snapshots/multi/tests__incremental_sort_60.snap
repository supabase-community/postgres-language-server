CREATE TABLE point_table ( a point, b INT );

CREATE INDEX "point_table_a_idx" ON point_table USING gist
(
  a
);

SELECT
  a,
  b,
  a <-> point(
  5,
  5
  )
  AS dist
FROM
  point_table
ORDER BY dist,
  b
LIMIT 1;

SELECT
  a,
  b,
  a <-> point(
  5,
  5
  )
  AS dist
FROM
  point_table
ORDER BY dist,
  b DESC
LIMIT 1;

SELECT
  *
FROM
  (SELECT
    *
  FROM
    tenk1
  ORDER BY four) AS t1
  INNER JOIN tenk1
  AS t2
  ON t1.four =
    t2.four AND
    t1.two =
    t2.two
ORDER BY t1.four,
  t1.two
LIMIT 1;

CREATE TABLE prt_tbl ( a INT, b INT ) PARTITION BY RANGE(a);

CREATE TABLE prt_tbl_1
PARTITION OF prt_tbl
FOR VALUES FROM (0) TO (100);

CREATE TABLE prt_tbl_2
PARTITION OF prt_tbl
FOR VALUES FROM (100) TO (200);

INSERT INTO prt_tbl
SELECT
  i % 200,
  i
FROM
  generate_series(
  1,
  1000
  ) AS i;

CREATE INDEX ON prt_tbl_1 USING btree ( a);

CREATE INDEX ON prt_tbl_2 USING btree ( a, b);

ANALYZE prt_tbl;

SET enable_seqscan = off;

SET enable_bitmapscan = off;

SELECT * FROM prt_tbl ORDER BY a, b;

SELECT
  *
FROM
  prt_tbl_1
UNION ALL
SELECT
  *
FROM
  prt_tbl_2
ORDER BY a,
  b;

RESET enable_bitmapscan;

RESET enable_seqscan;

DROP TABLE "prt_tbl";
