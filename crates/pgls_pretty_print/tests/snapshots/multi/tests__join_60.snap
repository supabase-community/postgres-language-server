  PRIMARY KEY,
  a1 BOOLEAN,
  a2 BOOLEAN
);

CREATE TEMPORARY TABLE nt2 (
  id INT
  PRIMARY KEY,
  nt1_id INT,
  b1 BOOLEAN,
  b2 BOOLEAN,
  FOREIGN KEY
  (nt1_id)
  REFERENCES nt1 (id)
);

CREATE TEMPORARY TABLE nt3 (
  id INT
  PRIMARY KEY,
  nt2_id INT,
  c1 BOOLEAN,
  FOREIGN KEY
  (nt2_id)
  REFERENCES nt2 (id)
);

INSERT INTO nt1 VALUES (1, TRUE, TRUE);

INSERT INTO nt1 VALUES (2, TRUE, FALSE);

INSERT INTO nt1 VALUES (3, FALSE, FALSE);

