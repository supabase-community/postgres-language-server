CREATE TEMPORARY TABLE xx ( pkxx INT );

CREATE TEMPORARY TABLE yy ( pkyy INT, pkxx INT );

INSERT INTO xx VALUES (1);

INSERT INTO xx VALUES (2);

INSERT INTO xx VALUES (3);

INSERT INTO yy VALUES (101, 1);

INSERT INTO yy VALUES (201, 2);

INSERT INTO yy VALUES (301, NULL);

SELECT
  yy.pkyy
  AS yy_pkyy,
  yy.pkxx
  AS yy_pkxx,
  yya.pkyy
  AS yya_pkyy,
  xxa.pkxx
  AS xxa_pkxx,
  xxb.pkxx
  AS xxb_pkxx
FROM
  yy
  LEFT OUTER JOIN (SELECT
    *
  FROM
    yy
  WHERE
    pkyy =
    101) AS yya
  ON yy.pkyy =
    yya.pkyy
  LEFT OUTER JOIN xx
  AS xxa
  ON yya.pkxx =
    xxa.pkxx
  LEFT OUTER JOIN xx
  AS xxb
  ON COALESCE(xxa.pkxx,
    1) =
    xxb.pkxx;

