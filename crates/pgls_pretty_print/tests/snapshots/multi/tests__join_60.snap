INSERT INTO nt2 VALUES (2, 2, TRUE, FALSE);

INSERT INTO nt2 VALUES (3, 3, FALSE, FALSE);

INSERT INTO nt3 VALUES (1, 1, TRUE);

INSERT INTO nt3 VALUES (2, 2, FALSE);

INSERT INTO nt3 VALUES (3, 3, TRUE);

SELECT
  nt3.id
FROM
  nt3
  AS nt3
  LEFT OUTER JOIN (SELECT
    nt2.*,
    nt2.b1 AND
    ss1.a3
    AS b3
  FROM
    nt2
    AS nt2
    LEFT OUTER JOIN (SELECT
      nt1.*,
      nt1.id IS NOT NULL
      AS a3
    FROM
      nt1) AS ss1
    ON ss1.id =
      nt2.nt1_id) AS ss2
  ON ss2.id =
    nt3.nt2_id
WHERE
  nt3.id =
  1 AND
  ss2.b3;

SELECT
  nt3.id
FROM
  nt3
  AS nt3
  LEFT OUTER JOIN (SELECT
    nt2.*,
    nt2.b1 AND
    ss1.a3
    AS b3
  FROM
    nt2
    AS nt2
    LEFT OUTER JOIN (SELECT
      nt1.*,
      nt1.id IS NOT NULL
      AS a3
    FROM
      nt1) AS ss1
    ON ss1.id =
      nt2.nt1_id) AS ss2
  ON ss2.id =
    nt3.nt2_id
WHERE
  nt3.id =
  1 AND
  ss2.b3;

