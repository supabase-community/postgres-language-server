SELECT
  x,
  CAST(x AS BIGINT) AS int8_value
FROM
  (VALUES
    (-CAST(2.5 AS DOUBLE PRECISION)),
    (-CAST(1.5 AS DOUBLE PRECISION)),
    (-CAST(0.5 AS DOUBLE PRECISION)),
    (CAST(0.0 AS DOUBLE PRECISION)),
    (CAST(0.5 AS DOUBLE PRECISION)),
    (CAST(1.5 AS DOUBLE PRECISION)),
    (CAST(2.5 AS DOUBLE PRECISION))) AS t (x);

SELECT
  x,
  CAST(x AS BIGINT) AS int8_value
FROM
  (VALUES
    (-CAST(2.5 AS NUMERIC)),
    (-CAST(1.5 AS NUMERIC)),
    (-CAST(0.5 AS NUMERIC)),
    (CAST(0.0 AS NUMERIC)),
    (CAST(0.5 AS NUMERIC)),
    (CAST(1.5 AS NUMERIC)),
    (CAST(2.5 AS NUMERIC))) AS t (x);

SELECT
  a,
  b,
  gcd(a, b),
  gcd(a, -b),
  gcd(b, a),
  gcd(-b, a)
FROM
  (VALUES
    (CAST(0 AS BIGINT), CAST(0 AS BIGINT)),
    (CAST(0 AS BIGINT), CAST(29893644334 AS BIGINT)),
    (
      CAST(288484263558 AS BIGINT),
      CAST(29893644334 AS BIGINT)
    ),
    (
      -CAST(288484263558 AS BIGINT),
      CAST(29893644334 AS BIGINT)
    ),
    (
      CAST(-9223372036854775808 AS BIGINT),
      CAST(1 AS BIGINT)
    ),
    (
      CAST(-9223372036854775808 AS BIGINT),
      CAST(9223372036854775807 AS BIGINT)
    ),
    (
      CAST(-9223372036854775808 AS BIGINT),
      CAST(4611686018427387904 AS BIGINT)
    )) AS v (a, b);

