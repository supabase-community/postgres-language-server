aa
AS (
  SELECT 'int4_tbl' AS u FROM int4_tbl LIMIT 1
)
INSERT INTO upsert
VALUES
  (1, 'x'),
  (999, 'y')
ON CONFLICT
(key)
DO
UPDATE
SET val = (SELECT u FROM aa)
RETURNING *;

