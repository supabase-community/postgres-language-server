  semijoin_unique_tbl AS t1,
  semijoin_unique_tbl AS t2
WHERE
  (t1.a, t2.a) IN
  (SELECT a + 1, b + 1 FROM semijoin_unique_tbl AS t3)
ORDER BY t1.a,
  t2.a;

