SELECT
  SUM(CAST(ss.tst AS INT))
FROM
  onek AS o
  INNER JOIN
    LATERAL (SELECT
      i.ten IN
      (SELECT f1 FROM int4_tbl WHERE f1 <= o.hundred)
      AS tst,
      random() AS r
    FROM
      onek AS i
    WHERE
      i.unique1 = o.unique1)
    AS ss
  ON TRUE
WHERE
  o.ten = 0;

SELECT
  SUM(CAST(ss.tst AS INT))
FROM
  onek AS o
  INNER JOIN
    LATERAL (SELECT
      i.ten IN
      (SELECT f1 FROM int4_tbl WHERE f1 <= o.hundred)
      AS tst,
      random() AS r
    FROM
      onek AS i
    WHERE
      i.unique1 = o.unique1)
    AS ss
  ON TRUE
WHERE
  o.ten = 0;

