SELECT f1 AS "Uncorrelated Field" FROM subselect_tbl WHERE f1 IN (SELECT f2 FROM subselect_tbl);

SELECT
  f1 AS "Uncorrelated Field"
FROM
  subselect_tbl
WHERE
  f1 IN
  (SELECT
    f2
