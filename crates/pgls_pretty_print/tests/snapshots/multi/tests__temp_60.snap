INSERT INTO whereami VALUES ('temp');

CREATE FUNCTION public.whoami()
RETURNS TEXT
AS 'select ''public''::text'
LANGUAGE "sql";

CREATE FUNCTION pg_temp.whoami()
RETURNS TEXT
AS 'select ''temp''::text'
LANGUAGE "sql";

