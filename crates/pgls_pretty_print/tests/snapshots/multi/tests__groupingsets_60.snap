FROM
  onek
GROUP BY two,
  ROLLUP (CAST(four AS TEXT))
ORDER BY 1;

SELECT
  SUM(ten)
FROM
  onek
GROUP BY ROLLUP (CAST(four AS TEXT)),
  two
ORDER BY 1;

