  gstest2
GROUP BY GROUPING SETS ((a, b), a)
HAVING
  a > 1 AND b > 1;

SELECT
  ten,
  GROUPING(ten)
FROM
  onek
GROUP BY GROUPING SETS (ten)
HAVING
  GROUPING(ten) >= 0
ORDER BY 2,
  1;

SELECT
  ten,
  GROUPING(ten)
FROM
  onek
GROUP BY GROUPING SETS (ten, four)
HAVING
