  DISTINCT four
  )
  FILTER (WHERE
    CAST(four AS TEXT) ~ '123')
FROM
  onek AS a
GROUP BY ROLLUP (ten);

SELECT
  *
FROM
  (VALUES
    (1),
    (2))
  AS v (a)
  LEFT OUTER JOIN
    LATERAL (SELECT
      v.a,
      four,
      ten,
      COUNT(*)
    FROM
      onek
    GROUP BY CUBE (four, ten))
    AS s
  ON TRUE
ORDER BY v.a,
  four,
  ten;

SELECT
  ARRAY(SELECT
    ROW(v.a, s1.*)
  FROM
    (SELECT
      two,
      four,
      COUNT(*)
    FROM
      onek
    GROUP BY CUBE (two, four)
    ORDER BY two,
      four)
    AS s1)
FROM
  (VALUES
    (1),
    (2))
  AS v (a);

SELECT
