SELECT
  ten,
  SUM(DISTINCT four)
FROM
  onek AS a
GROUP BY GROUPING SETS ((ten, four),
  ten)
HAVING
  EXISTS
  (SELECT
    1
  FROM
    onek AS b
  WHERE
    SUM(DISTINCT a.four) = b.four);

SELECT
  a,
  COUNT(*)
FROM
  gstest2
GROUP BY ROLLUP (a)
ORDER BY a;

SELECT
  a,
  COUNT(*)
FROM
  gstest2
GROUP BY ROLLUP (a)
HAVING
  a IS DISTINCT FROM 1
ORDER BY a;

SELECT
  a,
  COUNT(*)
FROM
  gstest2
GROUP BY ROLLUP (a)
HAVING
  a IS DISTINCT FROM 1
ORDER BY a;

SELECT
  v.c,
  (SELECT
    COUNT(*)
  FROM
    gstest2
  GROUP BY ()
  HAVING
    v.c)
FROM
  (VALUES
    (FALSE),
    (TRUE))
  AS v (c)
ORDER BY v.c;

SELECT
  v.c,
  (SELECT
    COUNT(*)
  FROM
    gstest2
  GROUP BY ()
  HAVING
    v.c)
FROM
  (VALUES
    (FALSE),
    (TRUE))
  AS v (c)
ORDER BY v.c;

SELECT
  a,
  b,
