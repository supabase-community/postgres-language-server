SELECT
  q.a,
  q.b = ROW(2),
  q.c = ARRAY[ROW(3)],
  q.d = ROW(ROW(4))
FROM
  unnest(
  ARRAY[ROW(1,
  ROW(2),
  ARRAY[ROW(3)],
  ROW(ROW(4))),
  ROW(2,
  ROW(3),
  ARRAY[ROW(4)],
  ROW(ROW(5)))]
  )
  AS q
  (
    a INT,
    b RECORD,
    c RECORD[],
    d RECORD
  );

