SELECT
  ts_headline(
  CAST('{"a": "aaa bbb", "b": {"c": "ccc ddd fff", "c1": "ccc1 ddd1"}, "d": ["ggg hhh", "iii jjj"]}'
  AS JSON),
  tsquery(
  'bbb & ddd & hhh'
  )
  );

SELECT
  ts_headline(
  'english',
  CAST('{"a": "aaa bbb", "b": {"c": "ccc ddd fff"}, "d": ["ggg hhh", "iii jjj"]}'
  AS JSON),
  tsquery(
  'bbb & ddd & hhh'
  )
  );

SELECT
  ts_headline(
  CAST('{"a": "aaa bbb", "b": {"c": "ccc ddd fff", "c1": "ccc1 ddd1"}, "d": ["ggg hhh", "iii jjj"]}'
  AS JSON),
  tsquery(
  'bbb & ddd & hhh'
  ),
  'StartSel = <, StopSel = >'
  );

