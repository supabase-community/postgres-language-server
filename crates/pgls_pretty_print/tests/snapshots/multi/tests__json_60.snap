CREATE TEMPORARY TABLE rows AS
  SELECT
    x,
    'txt' ||
    x
    AS y
  FROM
    generate_series(
    1,
    3
    ) AS x;

SELECT row_to_json(q, TRUE) FROM rows AS q;

SELECT
  row_to_json(
  ROW((SELECT
    array_agg(
    x
    )
    AS d
  FROM
    generate_series(
    5,
    10
    ) AS x)),
  FALSE
  );

ANALYZE rows;

SELECT
  attname,
  to_json(
  histogram_bounds
  )
  AS histogram_bounds
FROM
  pg_stats
WHERE
  tablename =
  'rows' AND
  schemaname =
  CAST(CAST(pg_my_temp_schema(

  )
  AS regnamespace)
  AS TEXT)
ORDER BY 1;

