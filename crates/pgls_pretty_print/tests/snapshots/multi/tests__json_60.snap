SELECT
  *,
  c IS NULL
  AS c_is_null
FROM
  json_to_record(
  CAST('{"a":1, "b":{"c":16, "d":2}, "x":8, "ca": ["1 2", 3], "ia": [[1,2],[3,4]], "r": {"a": "aaa", "b": 123}}'
  AS JSON)
  ) AS t (a INT,
  b JSON,
  c TEXT,
  x INT,
  ca CHAR(5)[],
  ia INT[][],
  r jpop);

SELECT
  *,
  c IS NULL
  AS c_is_null
FROM
  json_to_recordset(
  CAST('[{"a":1, "b":{"c":16, "d":2}, "x":8}]'
  AS JSON)
  ) AS t (a INT,
  b JSON,
  c TEXT,
  x INT);

