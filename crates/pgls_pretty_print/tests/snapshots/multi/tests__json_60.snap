CREATE TYPE jpop AS ( a TEXT, b INT, c TIMESTAMP );

CREATE DOMAIN js_int_not_null AS INT NOT NULL;

CREATE DOMAIN js_int_array_1d AS INT[]
  CHECK (array_length(
  value,
  1
  ) =
  3);

CREATE DOMAIN js_int_array_2d AS INT[][]
  CHECK (array_length(
  value,
  2
  ) =
  3);

CREATE TYPE j_unordered_pair AS ( x INT, y INT );

CREATE DOMAIN j_ordered_pair AS j_unordered_pair
  CHECK (value.x <=
  value.y);

CREATE TYPE jsrec AS (
  i INT,
  ia _int4,
  ia1 INT[],
  ia2 INT[][],
  ia3 INT[][][],
  ia1d js_int_array_1d,
  ia2d js_int_array_2d,
  t TEXT,
  ta TEXT[],
  c CHAR(10),
  ca CHAR(10)[],
  ts TIMESTAMP,
  js JSON,
  jsb JSONB,
  jsa JSON[],
  rec jpop,
  reca jpop[]
);

