SELECT
  COUNT(
  *
  )
FROM
  (SELECT
    json_object_keys(
    json_object(
    array_agg(
    g
    )
    )
    )
  FROM
    (SELECT
      unnest(
      ARRAY['f' ||
      n,
      CAST(n
      AS TEXT)]
      )
      AS g
    FROM
      generate_series(
      1,
      300
      ) AS n) AS x) AS y;

