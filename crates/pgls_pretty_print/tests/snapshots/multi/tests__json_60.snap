  '{"f2":{"f3":1},"f4":{"f5":null,"f6":"stringy"}}',
  'f4',
  'f5'
  ) IS NULL
  AS expect_true;

SELECT
  json_extract_path(
  '{"f2":{"f3":1},"f4":[0,1,2,null]}',
  'f4',
  '3'
  ) IS NULL
  AS expect_false;

