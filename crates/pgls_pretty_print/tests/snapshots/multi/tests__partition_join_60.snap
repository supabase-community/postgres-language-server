  t1.*,
  t2.*
FROM
  alpha
  AS t1
  INNER JOIN beta
  AS t2
  ON t1.a =
    t2.a AND
    t1.b =
    t2.b AND
    t1.c =
    t2.c
WHERE
  (t1.b >=
