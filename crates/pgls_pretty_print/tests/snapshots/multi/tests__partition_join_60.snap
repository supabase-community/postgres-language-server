WHERE
  a BETWEEN 490 AND 510;

SELECT
  t1.a,
  t1.phv,
  t2.b,
  t2.phv,
  t3.a + t3.b,
  t3.phv
FROM
  (SELECT
    50
    AS phv,
    *
  FROM
    prt1
  WHERE
    prt1.b =
    0) AS t1
  FULL OUTER JOIN (SELECT
    75
    AS phv,
    *
  FROM
    prt2
  WHERE
    prt2.a =
    0) AS t2
  ON t1.a =
    t2.b
  FULL OUTER JOIN (SELECT
    50
    AS phv,
    *
  FROM
    prt1_e
  WHERE
    prt1_e.c =
    0) AS t3
  ON t1.a =
    (t3.a + t3.b) / 2
WHERE
  t1.a =
  t1.phv OR
  t2.b =
  t2.phv OR
  (t3.a + t3.b) / 2 =
  t3.phv
ORDER BY t1.a,
  t2.b,
  t3.a + t3.b;

SELECT
  t1.a,
  t1.phv,
  t2.b,
  t2.phv,
  t3.a + t3.b,
  t3.phv
FROM
  (SELECT
    50
    AS phv,
    *
  FROM
    prt1
  WHERE
    prt1.b =
    0) AS t1
  FULL OUTER JOIN (SELECT
    75
    AS phv,
    *
  FROM
    prt2
  WHERE
    prt2.a =
    0) AS t2
  ON t1.a =
    t2.b
  FULL OUTER JOIN (SELECT
    50
    AS phv,
    *
  FROM
    prt1_e
  WHERE
    prt1_e.c =
    0) AS t3
  ON t1.a =
    (t3.a + t3.b) / 2
WHERE
  t1.a =
  t1.phv OR
  t2.b =
  t2.phv OR
  (t3.a + t3.b) / 2 =
  t3.phv
ORDER BY t1.a,
  t2.b,
  t3.a + t3.b;

SELECT
  t1.*
FROM
  prt1
  AS t1
WHERE
  t1.a IN (SELECT
    t1.b
  FROM
    prt2
    AS t1,
    prt1_e
    AS t2
  WHERE
    t1.a =
    0 AND
    t1.b =
    (t2.a + t2.b) / 2) AND
  t1.b =
  0
ORDER BY t1.a;

SELECT
  t1.*
FROM
  prt1
  AS t1
WHERE
  t1.a IN (SELECT
    t1.b
  FROM
    prt2
