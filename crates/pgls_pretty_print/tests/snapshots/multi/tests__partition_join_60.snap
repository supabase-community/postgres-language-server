  t1,
  t2
FROM
  prt1
  AS t1
  LEFT OUTER JOIN prt2
  AS t2
  ON t1.a =
    t2.b
WHERE
  t1.b =
  0
ORDER BY t1.a,
  t2.b;

SELECT
  t1,
  t2
FROM
  prt1
  AS t1
  LEFT OUTER JOIN prt2
  AS t2
  ON t1.a =
    t2.b
WHERE
  t1.b =
  0
ORDER BY t1.a,
  t2.b;

SELECT
  t1.a,
  t1.c,
  t2.b,
  t2.c
FROM
  prt1
  AS t1
  RIGHT OUTER JOIN prt2
  AS t2
  ON t1.a =
    t2.b
WHERE
  t2.a =
  0
ORDER BY t1.a,
  t2.b;

SELECT
  t1.a,
  t1.c,
  t2.b,
  t2.c
FROM
  prt1
  AS t1
  RIGHT OUTER JOIN prt2
  AS t2
  ON t1.a =
    t2.b
WHERE
  t2.a =
  0
ORDER BY t1.a,
  t2.b;

SELECT
  t1.a,
  t1.c,
  t2.b,
  t2.c
FROM
  (SELECT
    50
    AS phv,
    *
  FROM
    prt1
  WHERE
    prt1.b =
    0) AS t1
  FULL OUTER JOIN (SELECT
    75
    AS phv,
    *
  FROM
    prt2
  WHERE
    prt2.a =
    0) AS t2
  ON t1.a =
    t2.b
WHERE
  t1.phv =
  t1.a OR
  t2.phv =
  t2.b
ORDER BY t1.a,
  t2.b;

SELECT
  t1.a,
  t1.c,
  t2.b,
  t2.c
FROM
  (SELECT
    50
    AS phv,
    *
  FROM
    prt1
  WHERE
    prt1.b =
    0) AS t1
  FULL OUTER JOIN (SELECT
    75
    AS phv,
    *
  FROM
    prt2
  WHERE
    prt2.a =
    0) AS t2
  ON t1.a =
    t2.b
WHERE
  t1.phv =
  t1.a OR
  t2.phv =
  t2.b
ORDER BY t1.a,
  t2.b;

SELECT
  t1.a,
  t1.c,
  t2.b,
  t2.c
FROM
  prt1
  AS t1,
  prt2
  AS t2
WHERE
  t1.a =
  t2.b AND
  t1.a <
  450 AND
  t2.b >
  250 AND
  t1.b =
  0
ORDER BY t1.a,
  t2.b;

SELECT
  t1.a,
  t1.c,
  t2.b,
