SELECT
  t1.a,
  t1.c,
  t2.b,
  t2.c
FROM
  (SELECT
    *
  FROM
    prt1
  WHERE
    a <
    450) AS t1
  FULL OUTER JOIN (SELECT
    *
  FROM
    prt2
  WHERE
    b >
    250) AS t2
  ON t1.a =
    t2.b
WHERE
  t1.b =
  0 OR
  t2.a =
  0
ORDER BY t1.a,
