  200 AND
  t1.b <
  210) AND
  (t2.b >=
  100 AND
  t2.b <
  110 OR
  t2.b >=
  200 AND
  t2.b <
  210) AND
  t1.c IN ('0004',
  '0009')
ORDER BY t1.a,
  t1.b,
  t2.b;

SELECT
  t1.*,
