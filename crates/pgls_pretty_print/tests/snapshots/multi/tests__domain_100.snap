UPDATE dcomptable SET d1."r" = d1.r - 1, d1."i" = d1.i + 1 WHERE d1.i > 0;

CREATE RULE silly
AS ON DELETE TO dcomptable
DO INSTEAD
  UPDATE dcomptable
  SET d1."r" = d1.r - 1,
  d1."i" = d1.i + 1
  WHERE
    d1.i > 0;;

