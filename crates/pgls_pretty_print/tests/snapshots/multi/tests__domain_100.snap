CREATE OR REPLACE FUNCTION array_elem_check(NUMERIC)
RETURNS NUMERIC
AS '
declare
  x numeric(4,2)[1];
begin
  x[1] := $1;
  return x[1];
end'
LANGUAGE "plpgsql";

SELECT array_elem_check(121.00);

SELECT array_elem_check(1.23456);

CREATE DOMAIN mynums AS NUMERIC(4, 2)[1];

CREATE OR REPLACE FUNCTION array_elem_check(NUMERIC)
RETURNS NUMERIC
AS '
declare
  x mynums;
begin
  x[1] := $1;
  return x[1];
end'
LANGUAGE "plpgsql";

SELECT array_elem_check(121.00);

SELECT array_elem_check(1.23456);

CREATE DOMAIN mynums2 AS mynums;

CREATE OR REPLACE FUNCTION array_elem_check(NUMERIC)
RETURNS NUMERIC
AS '
