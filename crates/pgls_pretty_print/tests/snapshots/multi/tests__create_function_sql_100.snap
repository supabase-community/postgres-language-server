RETURNS INT
LANGUAGE "sql"
AS 'SELECT 1';

CREATE FUNCTION functest_is_4b(x INT DEFAULT functest_is_4a())
RETURNS INT
LANGUAGE "sql"
AS 'SELECT x';

CREATE SEQUENCE functest1;

CREATE FUNCTION functest_is_5(x INT DEFAULT nextval('functest1'))
RETURNS INT
LANGUAGE "sql"
AS 'SELECT x';

