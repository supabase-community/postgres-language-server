CREATE TABLE mchash (
  a INT,
  b TEXT,
  c JSONB
)
PARTITION BY HASH(a part_test_int4_ops,
b part_test_text_ops);

CREATE TABLE mchash1
PARTITION OF mchash
FOR VALUES WITH (MODULUS 4, REMAINDER 0);

