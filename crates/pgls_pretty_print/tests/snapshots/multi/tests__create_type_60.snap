(
  internallength = 4,
  input = int42_in,
  output = int42_out,
  alignment = INT,
  "default" = 42,
  passedbyvalue
);

CREATE TYPE text_w_default
(
  internallength = variable,
  input = text_w_default_in,
  output = text_w_default_out,
  alignment = INT,
  "default" = 'zippo'
);

