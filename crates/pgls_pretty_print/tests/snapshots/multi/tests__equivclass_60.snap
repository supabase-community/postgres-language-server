)
RETURNS BOOLEAN
STRICT
IMMUTABLE
LANGUAGE "internal"
AS 'int8eq';

CREATE OPERATOR = (PROCEDURE = int8alias2eq,
LEFTARG = int8alias2,
RIGHTARG = int8alias2,
COMMUTATOR = =,
RESTRICT = eqsel,
JOIN = eqjoinsel,
MERGES);

ALTER OPERATOR FAMILY integer_ops USING btree
  ADD OPERATOR 3 = (int8alias2,
  int8alias2);

