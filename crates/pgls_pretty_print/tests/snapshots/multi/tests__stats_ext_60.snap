CREATE FUNCTION
tftest(
  INT
)
RETURNS TABLE (
  "a" INT,
  "b" INT
)
AS '
SELECT $1, $1+i FROM generate_series(1,5) g(i);
'
LANGUAGE "sql"
IMMUTABLE
STRICT;

