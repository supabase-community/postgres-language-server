CREATE TABLE expr_stats_incompatible_test (
  c0 DOUBLE PRECISION,
  c1 BOOLEAN
  NOT NULL
);

CREATE STATISTICS expr_stat_comp_1
ON "c0",
"c1"
FROM expr_stats_incompatible_test;

INSERT INTO expr_stats_incompatible_test
VALUES (1234,
FALSE),
(5678,
TRUE);

ANALYZE expr_stats_incompatible_test;

SELECT
  c0
FROM
  ONLY expr_stats_incompatible_test
WHERE
  upper(
  'x'
  ) LIKE 'x' ||
  CAST('[0,1]'
  AS INT4RANGE) AND
  (c0 IN (0,
  1) OR
  c1);

DROP TABLE "expr_stats_incompatible_test";

