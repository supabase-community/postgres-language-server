CREATE FUNCTION
check_estimated_rows(
  TEXT
)
RETURNS TABLE (
  "estimated" INT,
  "actual" INT
)
LANGUAGE "plpgsql"
AS '
declare
    ln text;
    tmp text[];
    first_row bool := true;
begin
    for ln in
        execute format(''explain analyze %s'', $1)
    loop
        if first_row then
            first_row := false;
            tmp := regexp_match(ln, ''rows=(\d*) .* rows=(\d*)'');
            return query select tmp[1]::int, tmp[2]::int;
        end if;
    end loop;
end;
';

