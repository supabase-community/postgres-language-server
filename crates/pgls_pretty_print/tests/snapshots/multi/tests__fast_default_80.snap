  ADD COLUMN y INT NOT NULL DEFAULT 5;

CREATE TRIGGER a
  BEFORE UPDATE
  ON t
  FOR EACH ROW
  EXECUTE FUNCTION test_trigger();

SELECT * FROM t;

UPDATE t SET y = 2;

SELECT * FROM t;

