CREATE TABLE t1
AS
  SELECT
    CAST(1 AS INT) AS a,
    CAST(2 AS INT) AS b
  FROM
    generate_series(1, 20) AS q;

ALTER TABLE t1
  ADD COLUMN c TEXT;

SELECT
  a,
  stddev(
    CAST((SELECT
      SUM(1)
    FROM
      generate_series(1, 20) AS x)
    AS REAL)
  )
  OVER (
    PARTITION BY a,
    b,
    c
    ORDER BY b
  )
  AS z
FROM
  t1;

DROP TABLE "t";

CREATE FUNCTION test_trigger()
RETURNS trigger
LANGUAGE "plpgsql"
AS '

begin
    raise notice ''old tuple: %'', to_json(OLD)::text;
    if TG_OP = ''DELETE''
    then
       return OLD;
    else
       return NEW;
    end if;
end;

';

