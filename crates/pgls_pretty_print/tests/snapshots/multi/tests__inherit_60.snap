  "MIN"(
  x
  )
FROM
  (SELECT
    unique1
    AS x
  FROM
    tenk1
    AS a
  UNION ALL
  SELECT
    unique2
    AS x
  FROM
    tenk1
    AS b) AS s;

SELECT
  "MIN"(
  y
  )
FROM
  (SELECT
    unique1
    AS x,
    unique1
    AS y
  FROM
    tenk1
    AS a
  UNION ALL
  SELECT
    unique2
    AS x,
    unique2
    AS y
  FROM
    tenk1
    AS b) AS s;

