    attname
  FROM
    pg_attribute
  WHERE
    attrelid =
    conrelid AND
    attnum =
    conkey[1]),
  coninhcount,
  conislocal,
  connoinherit
FROM
  pg_constraint
WHERE
  contype =
  'n' AND
  CAST(CAST(conrelid
  AS REGCLASS)
  AS TEXT) LIKE 'inh\_nn\_%'
ORDER BY 2,
  1;

