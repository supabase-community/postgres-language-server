SELECT
  pc.relname,
  pgc.conname,
  pgc.contype,
  pgc.conislocal,
  pgc.coninhcount,
  pg_get_expr(
  pgc.conbin,
  pc.oid
  )
  AS consrc
FROM
  pg_class
  AS pc
  INNER JOIN pg_constraint
  AS pgc
  ON pgc.conrelid =
    pc.oid
WHERE
  pc.relname IN ('ac',
  'bc')
ORDER BY 1,
  2;

