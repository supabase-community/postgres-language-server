SELECT
  CAST(conrelid
  AS REGCLASS),
  conname,
  contype,
  conkey,
  coninhcount,
  conislocal,
  connoinherit
FROM
  pg_constraint
WHERE
  contype IN ('n',
  'p') AND
  CAST(CAST(conrelid
  AS REGCLASS)
  AS TEXT) IN ('inh_child',
  'inh_parent1',
  'inh_parent2')
ORDER BY 1,
  2;

