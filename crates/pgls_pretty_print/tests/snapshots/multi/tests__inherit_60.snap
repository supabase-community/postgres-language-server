WITH RECURSIVE r AS (SELECT
  CAST('inht1'
  AS REGCLASS)
  AS inhrelid
UNION ALL
SELECT
  c.inhrelid
FROM
  pg_inherits
  AS c,
  r
WHERE
  r.inhrelid =
  c.inhparent)
SELECT
  CAST(a.attrelid
  AS REGCLASS),
  a.attname,
  a.attinhcount,
  e.expected
FROM
  (SELECT
    inhrelid,
    "COUNT"(
    *
    )
    AS expected
  FROM
    pg_inherits
  WHERE
    inhparent IN (SELECT
      inhrelid
    FROM
      r)
  GROUP BY inhrelid) AS e
  INNER JOIN pg_attribute
  AS a
  ON e.inhrelid =
    a.attrelid
WHERE
  NOT attislocal
ORDER BY CAST(CAST(a.attrelid
  AS REGCLASS)
  AS NAME),
  a.attnum;

DROP TABLE "inht1", "inhs1" CASCADE;

