  contype,
  coninhcount,
  conislocal
FROM
  pg_constraint
WHERE
  CAST(CAST(conrelid
  AS REGCLASS)
  AS TEXT) IN ('inh_parent',
  'inh_child',
  'inh_child2',
  'inh_child3')
ORDER BY 2,
  1;

