  x,
  y
FROM
  (SELECT
    thousand
    AS x,
    tenthous
    AS y
  FROM
    tenk1
    AS a
  UNION ALL
  SELECT
    unique2
    AS x,
    unique2
    AS y
  FROM
    tenk1
    AS b) AS s
ORDER BY x,
  y;

SELECT
  ARRAY(SELECT
    f.i
  FROM
    ((SELECT
      d + g.i
    FROM
      generate_series(
      4,
      30,
      3
      ) AS d
    ORDER BY 1)
    UNION ALL
    (SELECT
      d + g.i
    FROM
      generate_series(
      0,
      30,
      5
      ) AS d
    ORDER BY 1)) AS f (i)
  ORDER BY f.i
  LIMIT 10)
FROM
  generate_series(
  1,
  3
  ) AS g (i);

SELECT
  ARRAY(SELECT
    f.i
  FROM
    ((SELECT
      d + g.i
    FROM
      generate_series(
      4,
      30,
      3
      ) AS d
    ORDER BY 1)
    UNION ALL
    (SELECT
      d + g.i
    FROM
      generate_series(
      0,
      30,
      5
      ) AS d
    ORDER BY 1)) AS f (i)
  ORDER BY f.i
  LIMIT 10)
FROM
  generate_series(
  1,
  3
  ) AS g (i);

