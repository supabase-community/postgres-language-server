    attnum =
    conkey[1]),
  coninhcount,
  conislocal
FROM
  pg_constraint
WHERE
  contype =
  'n' AND
  CAST(conrelid
  AS REGCLASS) IN ('inh_p1',
  'inh_p2',
  'inh_p3',
  'inh_p4',
  'inh_multiparent')
