CREATE FUNCTION dup(f1 ANYELEMENT, OUT f2 ANYELEMENT, OUT f3 ANYARRAY)
AS 'select $1, array[$1,$1]'
LANGUAGE "sql";

SELECT dup(22);

SELECT dup('xyz');

SELECT dup(CAST('xyz' AS TEXT));

SELECT * FROM dup(CAST('xyz' AS TEXT));

