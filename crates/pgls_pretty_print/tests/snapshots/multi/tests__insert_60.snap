CREATE TABLE inserttest2 ( f1 BIGINT, f2 TEXT );

CREATE RULE irule1
AS ON INSERT TO inserttest2
DO
  INSERT INTO inserttest (f3."if2"[1],
  f3."if2"[2])
  VALUES (new.f1,
  new.f2);;

CREATE RULE irule2
AS ON INSERT TO inserttest2
DO
  INSERT INTO inserttest (f4[1]."if1",
  f4[1]."if2"[2])
  VALUES (1,
  'fool'),
  (new.f1,
  new.f2);;

SELECT new.f1, new.f2;

