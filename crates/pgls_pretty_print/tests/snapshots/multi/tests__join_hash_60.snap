INSERT INTO hjtest_matchbits_t2 VALUES (2);

UPDATE hjtest_matchbits_t2 SET id = 2;

SELECT
  *
FROM
  hjtest_matchbits_t1 AS t1
  FULL OUTER JOIN
    hjtest_matchbits_t2 AS t2
  ON t1.id = t2.id
ORDER BY t1.id;

RESET parallel_setup_cost;

SET enable_parallel_hash = off;

SELECT
  *
FROM
