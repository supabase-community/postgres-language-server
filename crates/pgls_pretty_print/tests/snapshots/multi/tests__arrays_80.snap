SELECT
  array_length(
    array_positions(
      ARRAY(SELECT
        CAST('AAAAAAAAAAAAAAAAAAAAAAAAA'
        AS TEXT) ||
        i % 10
      FROM
        generate_series(1, 100) AS g (i)),
      'AAAAAAAAAAAAAAAAAAAAAAAAA5'
    ),
    1
  );

DO
$$
DECLARE
  o int;
  a int[] := ARRAY[1,2,3,2,3,1,2];
BEGIN
  o := array_position(a, 2);
  WHILE o IS NOT NULL
  LOOP
    RAISE NOTICE '%', o;
    o := array_position(a, 2, o + 1);
  END LOOP;
END
$$
LANGUAGE plpgsql;

