SELECT
  t.d1 AS t,
  i.f1 AS i,
  t.d1 + i.f1 AS add,
  t.d1 - i.f1 AS subtract
FROM
  timestamp_tbl
  AS t,
  interval_tbl
  AS i
WHERE
  t.d1 BETWEEN '1990-01-01' AND '2001-01-01' AND
  i.f1 BETWEEN '00:00' AND '23:00'
ORDER BY 1,
  2;

SELECT
  t.f1 AS t,
  i.f1 AS i,
  t.f1 + i.f1 AS add,
  t.f1 - i.f1 AS subtract
FROM
  time_tbl
  AS t,
  interval_tbl
  AS i
WHERE
  isfinite(i.f1)
ORDER BY 1,
  2;

SELECT
  t.f1 AS t,
  i.f1 AS i,
  t.f1 + i.f1 AS add,
  t.f1 - i.f1 AS subtract
FROM
  timetz_tbl
  AS t,
  interval_tbl
  AS i
WHERE
  isfinite(i.f1)
ORDER BY 1,
  2;

