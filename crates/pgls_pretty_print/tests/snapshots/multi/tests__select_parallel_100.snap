CREATE FUNCTION set_role_and_error(INT)
RETURNS INT
AS ' select 1 / $1 '
LANGUAGE "sql"
PARALLEL SAFE
SET ROLE TO regress_parallel_worker;

SET debug_parallel_query = 0;

