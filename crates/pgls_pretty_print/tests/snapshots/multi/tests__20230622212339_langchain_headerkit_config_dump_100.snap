        app.packages
      where
        handle = 'langchain' and
        partial_name = 'hybrid_search'
    ),
    (1, 1, 0),
    (1, 1, 1),
    '
SELECT pg_extension_config_dump(''documents'', '''');
SELECT pg_extension_config_dump(''documents_id_seq'', '''');
'
  );

insert into app.package_upgrades (
